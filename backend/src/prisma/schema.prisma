generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
  
enum UserRole {
  USER
  ADMIN
}

enum FriendStatus {
  PENDING
  FRIENDS
  NONE
}

enum RoomType {
  PUBLIC_BOARD
  PRIVATE_GROUP
  DIRECT_MESSAGE
}

model User {
  // User role
  role UserRole @default(USER)

  // Public fields
  id                  String   @id @default(uuid())
  username            String   @unique
  email               String   @unique
  profilePictureUrl   String?
  bio                 String?
  lastOnline          DateTime?
  isOnline            Boolean  @default(false)

  // Private Fields
  createdAt           DateTime @default(now())
  updatedAt           DateTime? @updatedAt

  // Authentication fields
  passwordHash        String

  // Spotify integration fields
  spotifyId           String?  @unique
  spotifyAccessToken  String? // This will be encrypted in the application layer before being stored in the database
  spotifyRefreshToken String? // This will be encrypted in the application layer before being stored in the database
  spotifyDisplayName  String?

  // Relations
  messages            Message[]
  rooms               RoomMember[]     // all rooms this user is in
  ownedRooms          Room[]           @relation("RoomOwner")
  friendsAsFirst      Friends[] @relation("UserAsFirst")
  friendsAsSecond     Friends[] @relation("UserAsSecond")
}

model Friends {
  userId1 String
  userId2 String
  status  FriendStatus @default(PENDING)

  user1   User @relation("UserAsFirst", fields: [userId1], references: [id], onDelete: Cascade)
  user2   User @relation("UserAsSecond", fields: [userId2], references: [id], onDelete: Cascade)

  @@id([userId1, userId2])
}

model Room {
  id          String     @id @default(uuid())
  type        RoomType

  name        String?    // null for DMs, or auto-generated "Chat with @user"
  description String?
  imageUrl    String?
  isPublic    Boolean    @default(false)   // for PUBLIC_BOARD

  createdBy   User?      @relation("RoomOwner", fields: [createdById], references: [id])
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime?  @updatedAt

  // Relations
  members     RoomMember[]
  messages    Message[]

  @@index([type])
  @@index([isPublic])
}

model RoomMember {
  id        String   @id @default(uuid())
  roomId    String
  userId    String

  joinedAt  DateTime @default(now())
  // Optional: role inside the room
  role      String?  // "owner", "admin", "member"  (or make enum later)

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
  @@index([roomId])
}

model Message {
  id          String    @id @default(uuid())
  roomId      String
  senderId    String

  content     String
  sentAt      DateTime  @default(now())
  editedAt    DateTime?

  // Optional powerful additions
  replyToId   String?   // self-reference for threads/replies
  isDeleted   Boolean   @default(false)

  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender      User      @relation(fields: [senderId], references: [id])
  replyTo     Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     Message[] @relation("MessageReplies")

  @@index([roomId, sentAt(sort: Desc)])
  @@index([senderId])
  @@index([replyToId])
}