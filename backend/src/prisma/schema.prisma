// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
  
enum UserRole {
  USER
  ADMIN
}

enum FriendStatus {
  PENDING
  FRIENDS
  NONE
}

model User {
  // User role
  role UserRole @default(USER)

  // Public fields
  id                  String   @id @default(uuid())
  username            String   @unique
  email               String   @unique
  profilePictureUrl   String?
  bio                 String?
  lastOnline          DateTime?
  isOnline            Boolean  @default(false)

  // Private Fields
  createdAt           DateTime @default(now())
  updatedAt           DateTime? @updatedAt

  // Authentication fields
  passwordHash        String

  // Spotify integration fields
  spotifyId           String?  @unique
  spotifyAccessToken  String? // This will be encrypted in the application layer before being stored in the database
  spotifyRefreshToken String? // This will be encrypted in the application layer before being stored in the database
  spotifyDisplayName  String?

  // Relations
  posts               Post[]
  messages            Message[]
  friendsAsFirst      Friends[] @relation("UserAsFirst")
  friendsAsSecond     Friends[] @relation("UserAsSecond")
}

model Friends {
  userId1 String
  userId2 String
  status  FriendStatus @default(PENDING)

  user1   User @relation("UserAsFirst", fields: [userId1], references: [id], onDelete: Cascade)
  user2   User @relation("UserAsSecond", fields: [userId2], references: [id], onDelete: Cascade)

  @@id([userId1, userId2])
}

model Post {
  id        String   @id @default(uuid())
  content   String
  timestamp DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  timestamp DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}